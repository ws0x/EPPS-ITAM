# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
.env*

# legacy Snipe-IT backup data (real employee PII) — this repo is public,
# never let raw backup files reach a commit
migration/*
!migration/README.md
!migration/*.mjs
!migration/*.ts
!migration/lib
!migration/lib/*.mjs
!migration/lib/*.d.mts
